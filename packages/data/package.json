{
  "name": "@no-bs-framework/data",
  "version": "0.0.1",
  "description": "Data fetching with optimistic updates for Your Framework",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@no-bs-framework/core": "workspace:*"
  },
  "devDependencies": {
    "react": "^18.2.0"
  },
  "keywords": [
    "react",
    "data-fetching",
    "cache",
    "optimistic-updates"
  ],
  "license": "MIT"
}
